# ===========================================
# AiTut - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# Database (Prisma - PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Gemini AI (Chat)
GEMINI_API_KEY="your-gemini-api-key"

# -------------------------------------------
# Optional - Paddle (ödeme, sonraya bırakılabilir)
# -------------------------------------------
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=
# NEXT_PUBLIC_PADDLE_PRICE_ANNUAL=

# -------------------------------------------
# Optional - Dev only (plan aktivasyonu)
# -------------------------------------------
# DEV_SECRET=
