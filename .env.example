# ===========================================
# AiTut - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# Database (Prisma - PostgreSQL)
# Supabase recommended:
# - DATABASE_URL: pooler host on port 6543
# - DIRECT_URL: direct host on port 5432
# - keep sslmode=require
DATABASE_URL="postgresql://user:password@host.pooler.supabase.com:6543/database?schema=public&sslmode=require"
DIRECT_URL="postgresql://user:password@db.host.supabase.co:5432/database?schema=public&sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Gemini AI (Chat)
GEMINI_API_KEY="your-gemini-api-key"

# -------------------------------------------
# Paddle Billing
# NEXT_PUBLIC_PADDLE_ENV: "sandbox" | "production"
#
# If checkout opens then shows "Something went wrong":
# - Use the same environment for ENV, client token, API key, and price IDs (all sandbox or all live).
# - In Paddle Dashboard: Checkout → Checkout settings → set "Default payment link"
#   (sandbox can use https://your-railway-app.up.railway.app/ or https://localhost/).
# - Checkout → Website approval: add your app domain (sandbox often auto-approved).
# -------------------------------------------
NEXT_PUBLIC_PADDLE_ENV="sandbox"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your-paddle-client-token"
PADDLE_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"

# Paddle Price IDs — Sandbox (test)
# Create in Paddle Dashboard → Catalog → Products → Prices
# On Railway/Vercel: set these in the service env; the app reads them at runtime via
# /api/paddle/checkout-config (no rebuild needed after adding them).
NEXT_PUBLIC_PADDLE_PRICE_MONTHLY="pri_sandbox_monthly"
NEXT_PUBLIC_PADDLE_PRICE_QUARTERLY="pri_sandbox_quarterly"
NEXT_PUBLIC_PADDLE_PRICE_YEARLY="pri_sandbox_yearly"
# Optional server-only aliases (same values; omit NEXT_PUBLIC if you prefer)
# PADDLE_PRICE_MONTHLY=
# PADDLE_PRICE_QUARTERLY=
# PADDLE_PRICE_YEARLY=
# PADDLE_CLIENT_TOKEN=

# -------------------------------------------
# Dev only
# -------------------------------------------
# DEV_SECRET=
# Optional: login page "test credentials" panel (local dev only)
# DEV_TEST_USER_EMAIL="e2e@test.com"
# DEV_TEST_USER_PASSWORD="testpass123"
