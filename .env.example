# ===========================================
# AiTut - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# Database (Prisma - PostgreSQL)
# Supabase recommended:
# - DATABASE_URL: pooler host on port 6543
# - DIRECT_URL: direct host on port 5432
# - keep sslmode=require
DATABASE_URL="postgresql://user:password@host.pooler.supabase.com:6543/database?schema=public&sslmode=require"
DIRECT_URL="postgresql://user:password@db.host.supabase.co:5432/database?schema=public&sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Gemini AI (Chat)
GEMINI_API_KEY="your-gemini-api-key"

# -------------------------------------------
# Optional - Paddle (ödeme, sonraya bırakılabilir)
# -------------------------------------------
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=
# NEXT_PUBLIC_PADDLE_PRICE_ANNUAL=

# -------------------------------------------
# Optional - Dev only (plan aktivasyonu)
# -------------------------------------------
# DEV_SECRET=

# -------------------------------------------
# Optional - Telegram orchestrator
# -------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=
# AGENT_WORKSPACE_ROOT=
# AGENT_DEFAULT_PROVIDER=auto
# OLLAMA_MODEL=qwen2.5-coder:7b
# SAFE_COMMANDS=git,npm,pnpm,yarn,node,npx,python,pytest,ls,dir,cat,type,rg,echo,pwd,cd
