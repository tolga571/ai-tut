# ─── Playwright E2E Test Ortam Değişkenleri ─────────────────────────────────
# Bu dosyayı kopyala: cp .env.test.example .env.test
# .env.test dosyası .gitignore'da tutulur — commit'e girme!

# ── Hedef URL ────────────────────────────────────────────────────────────────
# Lokal test için:
# BASE_URL=http://localhost:3000
#
# Railway (canlı) test için:
BASE_URL=https://jumplearner.com

# ── Aktif Planlı Test Kullanıcısı ─────────────────────────────────────────────
# Bu kullanıcının Railway DB'sinde var olması ve aktif Paddle planı olması gerekir.
# Paddle sandbox/test modundaysa test ödemesiyle aktif edebilirsin.
E2E_USER_EMAIL=paul@gmail.com
E2E_USER_PASSWORD=12345678

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
# Railway üzerinde NEXTAUTH_SECRET ile aynı olmalı (API testleri için gerekebilir)
# NEXTAUTH_SECRET=...
