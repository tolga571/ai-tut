{
  "name": "aitut-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push --accept-data-loss",
    "postinstall": "prisma generate",
    "test": "node --experimental-strip-types --experimental-loader ./tests/loader.mjs --test-force-exit --test 'tests/unit/**/*.test.ts' 'tests/integration/**/*.test.ts'",
    "test:unit": "node --experimental-strip-types --experimental-loader ./tests/loader.mjs --test-force-exit --test 'tests/unit/**/*.test.ts'",
    "test:integration": "node --experimental-strip-types --experimental-loader ./tests/loader.mjs --test-force-exit --test 'tests/integration/**/*.test.ts'",
    "test:watch": "node --experimental-strip-types --experimental-loader ./tests/loader.mjs --test-force-exit --test --watch 'tests/unit/**/*.test.ts'",
    "paddle:check": "node scripts/paddle-smoke.cjs",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:register": "npx playwright test --config=tests/e2e/playwright.config.ts tests/e2e/register.spec.ts",
    "test:e2e:security": "npx playwright test --config=tests/e2e/playwright.config.ts tests/e2e/api-security.spec.ts tests/e2e/access-control.spec.ts",
    "test:e2e:ai": "npx playwright test --config=tests/e2e/playwright.config.ts tests/e2e/ai-scope.spec.ts",
    "test:e2e:headed": "npx playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:report": "npx playwright show-report playwright-report",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "npx playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@paddle/paddle-js": "^1.6.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/config": "^7.5.0",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
