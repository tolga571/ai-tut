  {
    "id": "TC009",
    "title": "Complete onboarding with valid language preferences and reach dashboard",
    "description": "Verifies a logged-in user can select native language, target language, and CEFR level and proceed to the dashboard.",
    "category": "Onboarding (Language Preferences)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /en/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/en/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on \"Onboarding\" in the app navigation/menu"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/en/onboarding\""
      },
      {
        "type": "action",
        "description": "Select a native language from the native language dropdown"
      },
      {
        "type": "action",
        "description": "Select a target language from the target language dropdown"
      },
      {
        "type": "action",
        "description": "Select a CEFR level from the CEFR level dropdown"
      },
      {
        "type": "action",
        "description": "Click the \"Continue\" or \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/en/dashboard\""
      }
    ]
  },
