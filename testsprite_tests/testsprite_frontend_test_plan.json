[
  {
    "id": "TC001",
    "title": "Register a new user, select a plan, and reach onboarding",
    "description": "Verifies a user can register with valid details, choose a plan, and arrive at the onboarding page.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /en/register"
      },
      {
        "type": "action",
        "description": "Fill \"Test User\" into the name input field"
      },
      {
        "type": "action",
        "description": "Fill \"new.user.{{TIMESTAMP}}@example.com\" into the email input field"
      },
      {
        "type": "action",
        "description": "Fill \"ValidPass123!\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click submit/continue button"
      },
      {
        "type": "action",
        "description": "Select a plan (base, middle, or ultra)"
      },
      {
        "type": "action",
        "description": "Click to proceed to dashboard"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/en/onboarding\""
      }
    ]
  },
