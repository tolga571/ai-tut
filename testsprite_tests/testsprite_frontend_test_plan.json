  {
    "id": "TC014",
    "title": "Start a new AI conversation and receive response with translation and correction",
    "description": "Verifies a user can start a new conversation, send a message, and see an AI response that includes translation and a correction.",
    "category": "AI Chat",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /en/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Chat\" navigation link"
      },
      {
        "type": "assertion",
