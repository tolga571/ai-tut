    "id": "TC017",
    "title": "Rate limit error appears after repeated sends and message is not sent",
    "description": "Verifies the chat enforces the 30 messages/minute limit by showing the rate limit error and not sending the final message.",
    "category": "AI Chat",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /en/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Chat\" navigation link"
      },
      {
        "type": "action",
        "description": "Click the \"New Conversation\" control"
      },
      {
        "type": "action",
        "description": "Type \"Message 1\" into the message input"
      },
      {
        "type": "action",
        "description": "Click the \"Send\" button"
      },
      {
        "type": "action",
        "description": "Type \"Message 2\" into the message input"
      },
      {
        "type": "action",
        "description": "Click the \"Send\" button"
      },
      {
        "type": "action",
        "description": "Type \"Message 3\" into the message input"
      },
      {
        "type": "action",
        "description": "Click the \"Send\" button"
      },
      {
        "type": "action",
        "description": "Type \"Keep sending until rate limit triggers\" into the message input"
      },
      {
        "type": "action",
        "description": "Click the \"Send\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"30 messages/min\" is visible"
      }
    ]
  },
